`normalized RTs` = sprintf("%.2f \u00b1 %.2f", mean_rt, se_rt)) %>%
dplyr::select(Exp, Condition, strategy, accuracy, `normalized RTs`) %>%
arrange(Exp, strategy)
pairs_acc_strategy
