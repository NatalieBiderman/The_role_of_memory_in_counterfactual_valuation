df_final_decisions <- subset(df_final_decisions, !is.na(left_chosen)) %>%
mutate(chosen_trial_centered = ifelse(chosen_trial==1, 1, -1),
condition_centered = ifelse(condition==1, 1, -1))
# run logistic fits for each subject and detect their unchosen intercept
subs <- unique(df_final_decisions$PID)
subs_coefs <- data.frame()
for (i in 1:length(subs)){
sub_data <- subset(df_final_decisions, PID == subs[i])
m_sub <- glm(data = sub_data,
higher_outcome_chosen ~ chosen_trial_centered * condition_centered * zscored_delta_ratings,
family = binomial(link = "logit"))
subs_coefs[i,1] <- subs[i]
subs_coefs[i,2:9] <- m_sub$coefficients
}
colnames(subs_coefs) <- c("PID",rownames(as.data.frame(m_sub$coefficients)))
# compute unchosen intercept for the difference between the two conditions
subs_coefs <- mutate(subs_coefs,
unchosen_intercept_regular = `(Intercept)` - chosen_trial_centered - condition_centered + `chosen_trial_centered:condition_centered`,
unchosen_intercept_interference = `(Intercept)` - chosen_trial_centered + condition_centered - `chosen_trial_centered:condition_centered`,
unchosen_intercept_diff = unchosen_intercept_regular - unchosen_intercept_interference)
# compute power
compute_power <- function(desired_power,desired_sig_level,data,coef,null_point){
t_stats <- data %>%
dplyr::summarize(
t_value = as.numeric(t.test(!!sym(coef), rep(null_point, n()), paired=TRUE)["statistic"]),
p_value = as.numeric(t.test(!!sym(coef), rep(null_point, n()), paired=TRUE)["p.value"]),
cohens_d = cohensD(x=!!sym(coef),y=rep(null_point, n()),method="paired"),
power = as.numeric(pwr.t.test(n = n(), d = cohens_d, sig.level = desired_sig_level,
type = c("paired"))["power"]),
desired_sample = as.numeric(pwr.t.test(power = desired_power, d = cohens_d,
sig.level = desired_sig_level, type = c("paired"))["n"]))
return(t_stats)
}
power_pilot <- compute_power(0.99, 0.05, subs_coefs, "unchosen_intercept_diff",0)
